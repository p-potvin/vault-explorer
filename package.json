{
    "name": "vault-explorer",
    "version": "1.1.8",
    "description": "Re-discover the joys of browsing your files on a christmas morning or a rainy tuesday at work.",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dist": "electron-builder",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "electron": "^41.2.1",
        "electron-builder": "^26.8.1",
        "playwright": "^1.59.1"
    },
    "build": {
        "appId": "com.vaultwares.vaultexplorer",
        "icon": "build/icon.ico",
        "files": [
            "main.js",
            "preload.js",
            "index.html",
            "index.css",
            "themes.css",
            "themes.js",
            "js/**",
            "css/**",
            "src/**",
            "public/**",
            "powershell/**",
            "build/**",
            "python-scripts/**",
            "tools/**",
            "scripts/**",
            "vaultwares-themes/**",
            "node_modules/**",
            "!node_modules/playwright/**",
            "!node_modules/@playwright/**",
            "!node_modules/electron/**",
            "!node_modules/electron-builder/**",
            "!node_modules/app-builder-lib/**",
            "!node_modules/builder-util/**",
            "!node_modules/electron-publish/**",
            "!node_modules/@electron/rebuild/**",
            "!node_modules/dmg-builder/**"
        ],
        "asarUnpack": [
            "tools/**",
            "python-scripts/**"
        ],
        "win": {
            "target": "nsis"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "artifactName": "vault-explorer-${version}-setup.${ext}"
        }
    },
    "dependencies": {
        "express": "^5.2.1",
        "node-fetch": "^3.3.2"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "electron",
            "electron-winstaller"
        ]
    }
}
